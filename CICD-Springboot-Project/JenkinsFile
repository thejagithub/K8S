pipeline {
    agent any

    environment {
        ECR_REGISTRY = "707272278447.dkr.ecr.ap-northeast-1.amazonaws.com/springboot-app"
        ECR_REPO = "springboot-app"
        IMAGE_TAG = "latest"
        AWS_REGION = "ap-northeast-1"
        MINIKUBE_SERVER = "172.31.38.186"
        MINIKUBE_USER = "ubuntu"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/thejagithub/K8S.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Docker Build') {
            steps {
                sh """
                    docker build -t ${ECR_REPO}:${IMAGE_TAG} .
                    docker tag ${ECR_REPO}:${IMAGE_TAG} ${ECR_REGISTRY}/${ECR_REPO}:${IMAGE_TAG}
                """
            }
        }

        stage('ECR Login & Push') {
            steps {
                sh """
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ECR_REGISTRY}
                    docker push ${ECR_REGISTRY}/${ECR_REPO}:${IMAGE_TAG}
                """
            }
        }

        stage('Deploy to Minikube') {
    steps {
        sshagent(['minikube-ssh-key']) {
            sh """
                # Create k8s directory on Minikube EC2
                ssh -o StrictHostKeyChecking=no ${MINIKUBE_USER}@${MINIKUBE_SERVER} \
                    'mkdir -p /home/ubuntu/k8s'

                # Copy K8s manifests to Minikube EC2
                scp -o StrictHostKeyChecking=no \
                    k8s/deployment.yaml ${MINIKUBE_USER}@${MINIKUBE_SERVER}:/home/ubuntu/k8s/deployment.yaml

                scp -o StrictHostKeyChecking=no \
                    k8s/service.yaml ${MINIKUBE_USER}@${MINIKUBE_SERVER}:/home/ubuntu/k8s/service.yaml

                # SSH in and deploy
                ssh -o StrictHostKeyChecking=no ${MINIKUBE_USER}@${MINIKUBE_SERVER} '

                    # Login to ECR
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin ${ECR_REGISTRY}

                    # Create or update imagePullSecret
                    kubectl create secret docker-registry ecr-secret \
                        --docker-server=${ECR_REGISTRY} \
                        --docker-username=AWS \
                        --docker-password=\$(aws ecr get-login-password --region ${AWS_REGION}) \
                        --dry-run=client -o yaml | kubectl apply -f -

                    # Apply manifests
                    kubectl apply -f /home/ubuntu/k8s/deployment.yaml
                    kubectl apply -f /home/ubuntu/k8s/service.yaml

                    # Verify deployment
                    kubectl rollout status deployment/springboot-app
                '
            """
         }
       }
    }
  }

    post {
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}